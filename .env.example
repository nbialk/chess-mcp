# Analytics (optional). Tracking is a no-op when POSTHOG_API_KEY is unset,
# so forks and local dev run without sending any events.
#
# Use the PostHog *Project* API Key (starts with "phc_"), never a Personal
# API Key. The project key is write-only and safe to use server-side.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
